{
  "name": "posthog-bugfix-agent",
  "description": "Auto-fixes bugs when PostHog captures exceptions. Clones the repo, analyzes the error, opens a PR, and merges it.",
  "model": {
    "id": "claude-sonnet-4-6",
    "speed": "standard"
  },
  "mcp_servers": [
    {
      "type": "url",
      "name": "github",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    {
      "type": "url",
      "name": "posthog",
      "url": "https://mcp.posthog.com/mcp/"
    }
  ],
  "tools": [
    {
      "type": "agent_toolset_20260401",
      "default_config": {
        "enabled": true,
        "permission_policy": {
          "type": "always_allow"
        }
      }
    },
    {
      "type": "mcp_toolset",
      "mcp_server_name": "github",
      "default_config": {
        "enabled": true,
        "permission_policy": {
          "type": "always_allow"
        }
      }
    },
    {
      "type": "mcp_toolset",
      "mcp_server_name": "posthog",
      "default_config": {
        "enabled": true,
        "permission_policy": {
          "type": "always_allow"
        }
      }
    }
  ]
}
