// Triggers on $exception events. Deduplicates using CAS (compare-and-swap)
// on the PostHog error issue description field. Creates a Claude Managed Agent
// session that autonomously fixes the bug, opens+merges a PR, and resolves
// the PostHog error.

let errorType := event.properties.$exception_types[1] ?? 'Error'
let errorMessage := event.properties.$exception_values[1] ?? 'Unknown error'
let issueId := event.properties.$exception_issue_id ?? ''
let currentUrl := event.properties.$current_url ?? 'unknown'
let sources := event.properties.$exception_sources ?? []
let exList := event.properties.$exception_list ?? []

if (empty(issueId)) {
    print('No issue ID, skipping')
    return
}

let phBaseUrl := f'https://us.posthog.com/api/environments/{inputs.posthogProjectId}/error_tracking/issues/{issueId}/'
let phHeaders := {
    'Authorization': f'Bearer {inputs.posthogApiKey}',
    'Content-Type': 'application/json'
}

// Quick check: skip if already handled
let issueResponse := fetch(phBaseUrl, {
    'method': 'GET',
    'headers': phHeaders
})

if (issueResponse.status < 400) {
    let issueStatus := issueResponse.body.status ?? 'active'
    if (issueStatus == 'pending_release') {
        print(f'Issue {issueId} already pending_release, skipping')
        return
    }
    if (issueStatus == 'resolved') {
        print(f'Issue {issueId} already resolved, skipping')
        return
    }
    if (issueStatus == 'suppressed') {
        print(f'Issue {issueId} suppressed, skipping')
        return
    }
}

// CAS: write nonce, read back, check if we won
let nonce := f'bugfix-lock-{now()}-{event.uuid}'

fetch(phBaseUrl, {
    'method': 'PATCH',
    'headers': phHeaders,
    'body': {
        'status': 'pending_release',
        'description': nonce
    }
})

let readBack := fetch(phBaseUrl, {
    'method': 'GET',
    'headers': phHeaders
})

if (readBack.status < 400) {
    if (readBack.body.description != nonce) {
        print(f'Lost CAS race for issue {issueId}, skipping')
        return
    }
}

// We won the lock. Extract stack info.
let stackSummary := 'No stack trace'
if (length(exList) > 0) {
    let firstEx := exList[1]
    let frames := firstEx.stacktrace.frames ?? []
    if (length(frames) > 0) {
        let f := frames[1]
        stackSummary := f'{f.resolved_name ?? f.mangled_name ?? "?"} at {f.source ?? f.filename ?? "?"}:{f.line ?? "?"}'
    }
}

print(f'Won lock for {errorType}: {errorMessage}')

let sessionResponse := fetch('https://api.anthropic.com/v1/sessions', {
    'method': 'POST',
    'headers': {
        'Content-Type': 'application/json',
        'x-api-key': inputs.anthropicApiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-beta': 'managed-agents-2026-04-01'
    },
    'body': {
        'agent': inputs.agentId,
        'environment_id': inputs.environmentId,
        'title': f'{errorType}: {errorMessage}'
    }
})

if (sessionResponse.status >= 400) {
    throw Error(f'Failed to create session: {sessionResponse.status}: {sessionResponse.body}')
}

let sessionId := sessionResponse.body.id

let userMessage := f'GITHUB_TOKEN: {inputs.githubToken}\nREPO: {inputs.githubRepo}\nDEFAULT_BRANCH: {inputs.defaultBranch}\nGIT_AUTHOR_NAME: {inputs.gitAuthorName}\nGIT_AUTHOR_EMAIL: {inputs.gitAuthorEmail}\nPOSTHOG_API_KEY: {inputs.posthogApiKey}\nPOSTHOG_ISSUE_URL: {phBaseUrl}\n\nERROR:\n{errorType}: {errorMessage}\nURL: {currentUrl}\nStack: {stackSummary}\nFull: {jsonStringify(exList)}'

let eventsResponse := fetch(f'https://api.anthropic.com/v1/sessions/{sessionId}/events', {
    'method': 'POST',
    'headers': {
        'Content-Type': 'application/json',
        'x-api-key': inputs.anthropicApiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-beta': 'managed-agents-2026-04-01'
    },
    'body': {
        'events': [
            {
                'type': 'user.message',
                'content': [{'type': 'text', 'text': userMessage}]
            }
        ]
    }
})

if (eventsResponse.status >= 400) {
    throw Error(f'Failed to send event: {eventsResponse.status}: {eventsResponse.body}')
}

print(f'Agent dispatched: session {sessionId}')
